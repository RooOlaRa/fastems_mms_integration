<?xml version="1.0" encoding="utf-8" ?>
    <record id="ir_cron_export_mms_production_orders" model="ir.cron">
        <field name="name">MMS: Export Production Orders</field>
        <field name="model_id" ref="model_mms_backend" />
        <field name="state">code</field>
        <field name="code">model.cron_export_production_orders()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True" />
    </record>

    <record id="ir_cron_poll_mms_reports" model="ir.cron">
        <field name="name">MMS: Get manufacturing reports</field>
        <field name="model_id" ref="model_mms_backend" />
        <field name="state">code</field>
        <field name="code">model.cron_import_production_reports()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True" />
    </record>
</odoo>